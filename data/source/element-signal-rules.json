{
  "_meta": {
    "file": "element-signal-rules.json",
    "title": "核心取象：五行信号规则",
    "description": "供 coreSignalsEngine 使用的五行取象规则，只输出结构化信号。",
    "version": "1.0.0",
    "sourceRegistry": "00-来源-sources.json",
    "sourceIds": [
      "five-elements-wikipedia",
      "seasonal-strength"
    ],
    "status": "active"
  },
  "rules": [
    {
      "id": "element-strong-top2",
      "category": "elementSignals.strong",
      "name": "五行偏重",
      "conditions": {
        "scope": "element",
        "rank": "top",
        "maxItems": 2
      },
      "outputs": {
        "status": "偏重"
      },
      "evidenceTemplate": "{elementLabel}：{value}",
      "confidence": "medium",
      "needVerify": [
        "需要结合月令、藏干和组合关系复核"
      ],
      "sourceRefs": [
        {
          "sourceId": "five-elements-wikipedia"
        },
        {
          "sourceId": "seasonal-strength"
        }
      ],
      "sourceIds": [
        "five-elements-wikipedia",
        "seasonal-strength"
      ],
      "status": "active"
    },
    {
      "id": "element-weak-bottom2",
      "category": "elementSignals.weak",
      "name": "五行偏少",
      "conditions": {
        "scope": "element",
        "rank": "bottom",
        "maxItems": 2
      },
      "outputs": {
        "status": "偏少"
      },
      "evidenceTemplate": "{elementLabel}：{value}",
      "confidence": "medium",
      "needVerify": [
        "需要结合藏干是否有根、岁运是否补足复核"
      ],
      "sourceRefs": [
        {
          "sourceId": "five-elements-wikipedia"
        }
      ],
      "sourceIds": [
        "five-elements-wikipedia"
      ],
      "status": "active"
    },
    {
      "id": "element-missing-visible",
      "category": "elementSignals.missingVisible",
      "name": "明面不见",
      "conditions": {
        "scope": "visibleElement",
        "operator": "=",
        "value": 0
      },
      "outputs": {
        "status": "明面不见"
      },
      "evidenceTemplate": "明面{elementLabel}：{value}",
      "confidence": "high",
      "needVerify": [
        "明面不见仍需检查藏干和岁运是否出现"
      ],
      "sourceRefs": [
        {
          "sourceId": "core-stems-branches"
        },
        {
          "sourceId": "hidden-stems-xuenb"
        }
      ],
      "sourceIds": [
        "core-stems-branches",
        "hidden-stems-xuenb"
      ],
      "status": "active"
    }
  ]
}
