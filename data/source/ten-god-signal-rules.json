{
  "_meta": {
    "file": "ten-god-signal-rules.json",
    "title": "核心取象：十神信号规则",
    "description": "供 coreSignalsEngine 使用的十神取象与分组规则，只输出结构化信号。",
    "version": "1.0.0",
    "sourceRegistry": "00-来源-sources.json",
    "sourceIds": [
      "ten-gods",
      "ten-gods-overview"
    ],
    "status": "active"
  },
  "rules": [
    {
      "id": "ten-god-strong-top3",
      "category": "tenGodSignals.strong",
      "name": "突出的十神",
      "conditions": {
        "scope": "tenGod",
        "rank": "top",
        "maxItems": 3,
        "minCount": 1
      },
      "outputs": {
        "status": "突出"
      },
      "evidenceTemplate": "{name}：{count}",
      "confidence": "medium",
      "needVerify": [
        "需要检查该十神来自天干、地支主气还是藏干"
      ],
      "sourceRefs": [
        {
          "sourceId": "ten-gods"
        }
      ],
      "sourceIds": [
        "ten-gods"
      ],
      "status": "active"
    },
    {
      "id": "ten-god-weak-bottom3",
      "category": "tenGodSignals.weak",
      "name": "偏弱或不显的十神",
      "conditions": {
        "scope": "tenGod",
        "rank": "zeroOrBottom",
        "maxItems": 3
      },
      "outputs": {
        "zeroStatus": "不显",
        "bottomStatus": "偏弱"
      },
      "evidenceTemplate": "{name}：{count}",
      "confidence": "low",
      "needVerify": [
        "需要结合透干、藏干和柱位层次复核"
      ],
      "sourceRefs": [
        {
          "sourceId": "ten-gods"
